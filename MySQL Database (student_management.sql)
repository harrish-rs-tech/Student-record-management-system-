CREATE TABLE students(

student_id INT AUTO_INCREMENT PRIMARY KEY,

name VARCHAR(100),

email VARCHAR(100),

department VARCHAR(50),

year VARCHAR(20),

course VARCHAR(50),

attendance INT,

cgpa FLOAT

);
