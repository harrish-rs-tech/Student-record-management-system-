body{

font-family:'Poppins',sans-serif;

background:#f5f7fb;

}


.login-container{

height:100vh;

display:flex;

justify-content:center;

align-items:center;

}



.login-card{

background:white;

padding:40px;

width:400px;

border-radius:20px;

box-shadow:0px 10px 30px #ccc;

text-align:center;

}



.logo{

width:80px;

}



.sidebar{

position:fixed;

width:250px;

height:100vh;

background:#0d6efd;

color:white;

padding:25px;

}


.sidebar a{

display:block;

color:white;

text-decoration:none;

padding:15px;

border-radius:10px;

}


.sidebar a:hover{

background:white;

color:#0d6efd;

}



.main{

margin-left:270px;

padding:30px;

}



.navbar{

background:white;

padding:15px;

border-radius:15px;

box-shadow:0px 5px 15px #ddd;

}



.search{

width:300px;

padding:10px;

border-radius:20px;

border:1px solid #ddd;

}



.card-box{

background:white;

padding:25px;

border-radius:20px;

box-shadow:0px 5px 20px #ddd;

margin-top:20px;

transition:.3s;

}


.card-box:hover{

transform:translateY(-5px);

}


@media(max-width:768px){

.sidebar{

width:80px;

}

.main{

margin-left:90px;

}


}
